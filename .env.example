# Copy to .env for local `netlify dev`, and set the same variables in the
# Netlify dashboard (Site settings → Environment variables) for production.

# Your Anthropic API key. NEVER commit the real value. Stays server-side only.
ANTHROPIC_API_KEY=sk-ant-...

# Shared password that gates the public site. Anyone with it can chat (and spend
# your tokens), so treat it as a light guard, not real auth. Leave unset to make
# the site fully open (not recommended for a public deploy).
SITE_PASSWORD=change-me
